# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL in production; tests/demo use SQLite automatically via TESTING=1
DATABASE_URL=postgresql://user:password@localhost:5432/appdb

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_HOURS=24

# ── CORS / frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# ════════════════════════════════════════════════════════════════════════════════
# AI PROVIDERS — Choose free or paid options, switch by configuration only
# ════════════════════════════════════════════════════════════════════════════════

# 🎯 RECOMMENDED FOR FREE TIER (no paid API required):
# ─────────────────────────────────────────────────────────────────────────────────
# 1. Chat LLM: Use Gemini (free tier available at https://ai.google.dev)
#    - Get free API key at https://aistudio.google.com/apikey
#    - Includes 60 requests per minute free tier
# 2. Embeddings: Use local HuggingFace model (no API key needed)
#    - Downloads ~500MB once, then works offline
#    - Perfect for development and small projects

# For FREE tier (recommended):
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
RUNTIME_LLM=gemini-2.0-flash
LLM_API_KEY=AIza...  # Get free key at https://aistudio.google.com/apikey

EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=local-huggingface  # Special value: uses local model, no API key needed
EMBEDDING_DIM=384

# ────────────────────────────────────────────────────────────────────────────────
# ALTERNATIVE PROVIDERS (uncomment and fill in your API keys):
# ────────────────────────────────────────────────────────────────────────────────

# Option A: OpenAI (paid)
#OPENAI_API_KEY=sk-...  # https://platform.openai.com/api-keys
#LLM_BASE_URL=
#RUNTIME_LLM=gpt-4o
#EMBEDDING_MODEL=text-embedding-3-small
#EMBEDDING_DIM=1536

# Option B: Groq (free tier available at https://console.groq.com)
#LLM_BASE_URL=https://api.groq.com/openai/v1
#RUNTIME_LLM=llama-3.3-70b-versatile
#LLM_API_KEY=gsk_...
# Groq has NO embeddings API — use Gemini or OpenAI embeddings instead:
#EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#EMBEDDING_MODEL=text-embedding-004
#EMBEDDING_API_KEY=AIza...

# Option C: Gemini for both (free tier, both LLM and embeddings)
#LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#RUNTIME_LLM=gemini-2.0-flash
#LLM_API_KEY=AIza...
#EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#EMBEDDING_MODEL=text-embedding-004
#EMBEDDING_API_KEY=AIza...

# ────────────────────────────────────────────────────────────────────────────────
# RAG settings
RAG_TOP_K=5
